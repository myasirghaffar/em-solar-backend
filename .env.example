# =============================================================================
# EM Solar API — local / CI environment (not committed; copy to `.env`)
# =============================================================================

# --- Required: one Postgres connection for Worker + Drizzle + scripts -------
# Supabase → Project Settings → Database → Connection string → URI
#
# Prefer Transaction pooler (port 6543) for Cloudflare Workers.
# If CLI tools fail (circuit breaker / IPv4), try Session pooler (port 5432, same host, user postgres.<ref>).
# URL-encode special characters in the password (; = ) @ # etc.).
#
# postgresql://postgres.PROJECT_REF:ENCODED_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
DATABASE_URL=

# JWT secrets (use long random strings; must match .dev.vars for `wrangler dev`)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# --- Cloudflare Worker production (`wrangler deploy`) -------------------------
# Put secrets on the Worker (Dashboard → Workers → em-solar-api → Settings → Variables, or CLI):
#   wrangler secret put DATABASE_URL
#   wrangler secret put JWT_ACCESS_SECRET
#   wrangler secret put JWT_REFRESH_SECRET
# Without DATABASE_URL (or a Hyperdrive binding), live API routes that use the DB return 503.
# CORS: add every storefront origin to wrangler.toml [vars] ALLOWED_ORIGINS (comma-separated, no trailing slash).
# If you set ALLOWED_ORIGINS in the dashboard too, include the same origins (dashboard can override).
#
# Common mistakes:
# - Do NOT add VITE_API_URL to this API Worker. Vite only runs when building the *frontend* repo
#   (em-solar). Put VITE_API_URL in Cloudflare Pages / the frontend project’s env at build time,
#   or omit it and rely on DEFAULT_PRODUCTION_API_URL in em-solar/src/config/api.ts.
# - If the browser shows 302 to *.cloudflareaccess.com: Cloudflare Zero Trust (Access) is in front
#   of the API hostname. Remove that Access app or add a Bypass for public paths — otherwise fetch()
#   from your SPA never reaches this Worker.

# Browser app URL (no trailing slash). Used in verification + password reset emails.
FRONTEND_APP_URL=https://energymart-pk.vercel.app

# --- Transactional email (Resend) — required for real inbox delivery -----------------
# 1) Create a free account at https://resend.com → API Keys → create key → paste below.
# 2) EMAIL_FROM: use "onboarding@resend.dev" only for tests, or verify your domain and use e.g. "EnergyMart <noreply@yourdomain.com>".
# 3) Until RESEND_API_KEY is set, the API does not send mail; signup/password responses include a verification URL in JSON for local testing.
RESEND_API_KEY=
EMAIL_FROM=EnergyMart <onboarding@resend.dev>
# Optional: legacy flag; no longer required — dev links are returned whenever Resend is unset.
DEV_EXPOSE_EMAIL_LINKS=true

# Optional: POST /auth/register-admin JSON body must include inviteSecret matching this value.
ADMIN_INVITE_SECRET=

# --- Optional: Supabase project (REST/Storage later; Worker can use as vars) ---
# Project URL (Settings → API → Project URL)
SUPABASE_URL=https://geqhoiiqwlymljdgppco.supabase.co
# Dashboard → Project Settings → API → service_role (server only, never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=
# Dashboard → Project Settings → API → anon / "publishable" key (public; browser clients)
SUPABASE_ANON_KEY=

# --- Optional: first admin user (`npm run db:seed-admin` after db:push) -----
# Login password for the API (not the Supabase Postgres DATABASE_URL password).
# If ADMIN_EMAIL is omitted, seed-admin uses admin@energymart.pk (same as storefront admin).
ADMIN_EMAIL=admin@energymart.pk
ADMIN_PASSWORD=change-me-min-8-chars
ADMIN_NAME=EnergyMart Admin

# --- Optional: HTML status page (/, /status) — “last deploy / merge” line ----------
# ENVIRONMENT defaults from NODE_ENV when unset (Node dev). For Workers, set in wrangler.toml [vars].
ENVIRONMENT=development
# ISO 8601 time of last production deploy (set in CI when you deploy).
DEPLOYED_AT=
# Same idea as DEPLOYED_AT if your pipeline uses BUILD_TIME instead.
BUILD_TIME=
GIT_COMMIT=
GIT_COMMIT_SHORT=
