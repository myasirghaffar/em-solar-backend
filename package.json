{
  "name": "em-solar-api",
  "version": "1.0.0",
  "private": true,
  "description": "EM Solar API on Cloudflare Workers (Hono + Drizzle + PostgreSQL)",
  "scripts": {
    "start": "tsx src/dev-server.ts",
    "dev": "tsx src/dev-server.ts",
    "dev:wrangler": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed-admin": "tsx src/scripts/seed-admin.ts",
    "db:seed-store": "tsx src/scripts/seed-store.ts",
    "db:apply-sql-schema": "tsx src/scripts/apply-sql-schema.ts",
    "db:reset-schema": "tsx src/scripts/reset-schema.ts",
    "db:wipe-all": "tsx src/scripts/wipe-public-schema.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "@hono/zod-validator": "^0.4.2",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.3",
    "hono": "^4.6.14",
    "jose": "^5.9.6",
    "postgres": "^3.4.5",
    "tsx": "^4.19.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250411.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "drizzle-kit": "^0.30.1",
    "typescript": "^5.7.2",
    "wrangler": "^3.114.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
